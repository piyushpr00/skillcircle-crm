{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "public/index.html", "use": "@vercel/static" },
    { "src": "public/login.html", "use": "@vercel/static" },
    { "src": "public/app.js", "use": "@vercel/static" },
    { "src": "public/style.css", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api(.*)", "dest": "/api/index.js" },
    { "src": "/static/(.*)", "dest": "/public/$1" },
    { "src": "/login.html", "dest": "/public/login.html" },
    { "src": "/app.js", "dest": "/public/app.js" },
    { "src": "/style.css", "dest": "/public/style.css" },
    { "src": "/.*\\.html$", "dest": "/public/index.html" },
    { "src": "/.*", "dest": "/public/index.html" }
  ]
}
